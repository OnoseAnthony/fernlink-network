{
  "name": "fernlink-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Fernlink decentralized Solana transaction verification mesh",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "blockchain",
    "mesh",
    "p2p",
    "verification",
    "ble"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fernlink-Protocol/fernlink-network"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "lz4js": "^0.2.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/web-bluetooth": "^0.0.21",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
